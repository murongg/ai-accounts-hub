{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-start-dragging",
    "opener:default",
    "updater:default",
    {
      "identifier": "opener:allow-open-path",
      "allow": [{ "path": "$APPDATA/codex" }, { "path": "$APPDATA/codex/**" }]
    }
  ]
}
