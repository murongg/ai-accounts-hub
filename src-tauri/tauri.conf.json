{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ai-accounts-hub",
  "version": "0.1.0",
  "identifier": "com.murong.ai-accounts-hub",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "",
        "width": 1360,
        "height": 800,
        "titleBarStyle": "Overlay",
        "transparent": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "untrusted comment: minisign public key: 42417E2B7685C5AD\nRWStxYV2K35BQhNYQmEp0QJ1nUl0E4J7vfFaeXYWikdyU5b9X73Z1VWN",
      "endpoints": [
        "https://github.com/murong/ai-accounts-hub/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
