{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AI Accounts Hub",
  "version": "0.3.6",
  "identifier": "com.murong.ai-accounts-hub",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "",
        "width": 1360,
        "height": 800,
        "titleBarStyle": "Overlay",
        "transparent": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "resources": [
      "../public/icon.svg",
      "../src/assets/openai.svg",
      "../src/assets/claude-color.svg",
      "../src/assets/gemini-color.svg",
      "native/macos/provider-icons/gemini.png"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDQyNDE3RTJCNzY4NUM1QUQKUldTdHhZVjJLMzVCUWhOWVFtRXAwUUoxblVsMEU0Sjd2ZkZhZVhZV2lrZHlVNWI5WDczWjFWV04K",
      "endpoints": [
        "https://github.com/murongg/ai-accounts-hub/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
